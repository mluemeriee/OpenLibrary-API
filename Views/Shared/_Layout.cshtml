<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - The Literary Archives</title>    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="page-shell">
        <header class="site-header">
            <div class="container">
                <div class="header-bar">
                    <div class="brand">
                        <div class="brand-mark" aria-hidden="true">⌘</div>
                        <div class="brand-copy">
                            <small>Community Library Portal</small>
                            <strong>The Literary Archives</strong>
                        </div>
                    </div>
                    <nav class="nav-links" aria-label="Primary navigation">
                        <a asp-controller="Home" asp-action="Index">Discover</a>
                        <a href="#catalog">Catalog</a>
                        <a href="#spaces">Reading Spaces</a>
                        <a href="#visit">Plan a Visit</a>
                    </nav>
                </div>
            </div>
        </header>

        <main role="main">
            <div class="container">
                @RenderBody()
            </div>
        </main>

        <footer class="border-top footer text-muted">
            <div class="container">
                All rights reserved to all authors. &copy; 2026 - The Literary Archives
            </div>
        </footer>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>